GOOGLE_API_KEY=
GOOGLE_OAUTH_ACCESS_TOKEN=
GOOGLE_OAUTH_CLIENT_SECRETS_FILE=C:/path/to/oauth-client-secret.json
GOOGLE_OAUTH_CLIENT_CONFIG_JSON=
GOOGLE_OAUTH_TOKEN_FILE=C:/path/to/oauth-token.json
GOOGLE_OAUTH_LOCAL_SERVER_PORT=0
GOOGLE_OAUTH_OPEN_BROWSER=true
GOOGLE_SERVICE_ACCOUNT_FILE=C:/path/to/service-account.json
